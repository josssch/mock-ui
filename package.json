        "@sveltejs/kit": "^2.57.1",
        "@sveltejs/vite-plugin-svelte": "^7.0.0",
        "prettier": "^3.8.3",
        "prettier-plugin-svelte": "^3.5.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "svelte": "^5.55.4",
        "svelte-check": "^4.4.6",
        "typescript": "^6.0.3",
        "typescript-svelte-plugin": "^0.3.51",
        "vite": "^8.0.9"
    },
    "dependencies": {
        "@tailwindcss/vite": "^4.2.2",
